# Upstream Hospital Directory API base URL.
UPSTREAM_BASE_URL=https://hospital-directory.onrender.com

# Max simultaneous create calls against the upstream (bounded concurrency).
# Keep modest for a free-tier Render box to avoid throttling / 502s.
MAX_CONCURRENCY=10

# Per-call HTTP timeout in seconds (generous for Render cold starts).
REQUEST_TIMEOUT_SECONDS=30

# Retry policy for transient upstream failures (timeouts, 429, 5xx).
MAX_RETRIES=3
BACKOFF_BASE_SECONDS=0.5

# Hard cap on rows per CSV.
MAX_ROWS=20

# Log verbosity: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO

# Activation policy on partial failure:
#   false -> strict: activate only when all rows succeed (matches spec literal).
#   true  -> lenient: activate the batch even if some rows failed.
ACTIVATE_ON_PARTIAL_FAILURE=false
